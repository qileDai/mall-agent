# 复制为 `.env` 后填写。勿提交真实密钥。
#
# OpenAI 官方或兼容网关（中转）：BASE 一般指向 .../v1
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
# 中转站限流时 SDK 会自动重试；可酌情调小重试次数
OPENAI_MAX_RETRIES=2
OPENAI_TIMEOUT_SECONDS=120

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=mall_cs_kb
# QDRANT_API_KEY=

# Redis（会话 / 限流；不可用时可设 REDIS_ENABLED=false）
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_ENABLED=true
SESSION_TTL_SECONDS=86400

# LangSmith（与 LangChain 共用环境变量名）
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
# 若只配置 LANGSMITH_API_KEY，后端也会映射到 LANGCHAIN_API_KEY
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=mall-agent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# CORS（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# 上下文 Token 预算
SESSION_MAX_MESSAGES=16
RAG_TOP_K=4
RAG_CHUNK_MAX_CHARS=480
AGGREGATE_SUMMARY_MAX_CHARS=800
